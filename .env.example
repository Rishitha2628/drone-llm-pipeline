# Copy to .env (git-ignored) and fill in ONE provider's key.
# Every mission also runs with --no-llm and needs no key at all.

# gemini | groq | anthropic
LLM_PROVIDER=gemini

# Free tier at aistudio.google.com — flash-lite tiers have the friendliest RPM
# limits. NOTE: Google gates older models for new keys; if you get a 404 naming
# the model, list your key's models and pick a current flash-tier one.
GEMINI_API_KEY=your-key-here
PLANNER_MODEL=gemini-3.1-flash-lite

# Alternatives:
# GROQ_API_KEY=gsk_your-key-here          # console.groq.com (llama-3.3-70b-versatile)
# ANTHROPIC_API_KEY=sk-ant-your-key-here  # console.anthropic.com (claude-sonnet-4-6)
