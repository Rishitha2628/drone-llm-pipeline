# Copy to .env (git-ignored) and fill in ONE provider's key.
# Every mission also runs with --no-llm and needs no key at all.

# gemini | groq | anthropic
LLM_PROVIDER=gemini

# Free tier at aistudio.google.com — flash-lite has the friendliest RPM limits
GEMINI_API_KEY=your-key-here
PLANNER_MODEL=gemini-2.5-flash-lite

# Alternatives:
# GROQ_API_KEY=gsk_your-key-here          # console.groq.com (llama-3.3-70b-versatile)
# ANTHROPIC_API_KEY=sk-ant-your-key-here  # console.anthropic.com (claude-sonnet-4-6)
